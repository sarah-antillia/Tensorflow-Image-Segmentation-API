; train_eval_infer.config
; 2023/09/22 (C) antillia.com


[model]
image_width    = 256
image_height   = 256
;image_width    = 512
;image_height   = 512

efficientnet   = "B0"
image_channels = 3
num_classes    = 1


dropout_rate   = 0.06
learning_rate  = 0.0001
clipvalue      = 0.5
loss           = "binary_crossentropy"
metrics        = ["binary_accuracy"]
show_summary   = False

[train]
epochs        = 100
batch_size    = 2
patience      = 10
metrics       = ["binary_accuracy", "val_binary_accuracy"]
model_dir     = "./models"
; 2023/09/22 Modified the following line
save_weights_only = True

eval_dir      = "./eval"
image_datapath = "../../../dataset/MultipleMyeloma/train/images/"
mask_datapath  = "../../../dataset/MultipleMyeloma/train/masks/"
create_backup  = False

[eval]
image_datapath = "../../../dataset/MultipleMyeloma/valid/images/"
mask_datapath  = "../../../dataset/MultipleMyeloma/valid/masks/"

[infer] 
images_dir    = "./mini_test" 
output_dir    = "./mini_test_output"
merged_dir    = "./mini_test_output_merged"

[tiledinfer] 
overlapping  = 64
images_dir   = "./4k_mini_test"
output_dir   = "./4k_tiled_mini_test_output"

[mask]
blur      = True
binarize  = True
threshold = 74
