; train_eval_infer.config
; 2023/09/04 (C) antillia.com

[model]
image_width    = 256
image_height   = 256
image_channels = 3
num_classes    = 1
base_filters   = 16
num_layers     = 6
dropout_rate   = 0.08
learning_rate  = 0.001

loss           = "binary_crossentropy"
metrics        = ["binary_accuracy"]
show_summary   = False

[train]
epochs        = 100
batch_size    = 4
patience      = 10
model_dir     = "./models"
eval_dir      = "./eval"
metrics       = ["binary_accuracy", "val_binary_accuracy"]
image_datapath = "../../../dataset/ALL/train/original/Early"
mask_datapath  = "../../../dataset//ALL/train/segmented/Early"
;category       = "Early"

[eval]
image_datapath = "../../../dataset/ALL/test/original/Early"
mask_datapath  = "../../../dataset/ALL/test/segmented/Early"
;category       = "Early"

[infer] 
images_dir    = "./mini_test" 
output_dir    = "./mini_test_output"
merged_dir    = "./mini_test_output_merged"

[mask]
blur      = True
binarize  = True
threshold = 150
