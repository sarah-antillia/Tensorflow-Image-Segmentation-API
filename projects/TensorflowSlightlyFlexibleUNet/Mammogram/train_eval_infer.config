; train_eval_infer.config
; 2023/09/04 (C) antillia.com

[model]
image_width    = 512
image_height   = 512

image_channels = 3
num_classes    = 1
base_filters   = 16
base_kernels   = (7,7)
num_layers     = 7
dropout_rate   = 0.08
learning_rate  = 0.0001
clipvalue      = 0.5
dilation       = (2,2)
normalization  = True

;loss           = "binary_crossentropy"
loss           = "iou_loss"
metrics        = ["iou_coef"]
;metrics        = ["binary_accuracy", "sensitivity", "specificity"]

show_summary   = False

[train]
epochs        = 100
batch_size    = 4
;For evaluation
;batch_size    = 2

patience      = 10
metrics       = ["iou_coef", "val_iou_coef"]

model_dir     = "./models"
eval_dir      = "./eval"

image_datapath = "../../../dataset/Mammogram/train/images/"
mask_datapath  = "../../../dataset/Mammogram/train/masks/"
create_backup  = False

[eval]
image_datapath = "../../../dataset/Mammogram/test/images/"
mask_datapath  = "../../../dataset/Mammogram/test/masks/"

[infer] 
images_dir    = "../../../dataset/Mammogram/test/fgt_seg"
output_dir    = "./test_output"
merged_dir    = "./test_output_merged"


[mask]
blur      = False
binarize  = True
threshold = 100


