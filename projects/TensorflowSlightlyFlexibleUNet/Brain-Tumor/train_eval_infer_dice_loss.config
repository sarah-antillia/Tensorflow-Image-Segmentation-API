; train_eval_infer_dice_losss.config
; 2023/09/04 (C) antillia.com

[model]
image_width    = 256
image_height   = 256
image_channels = 3
num_classes    = 1
base_filters   = 16
num_layers     = 6
dropout_rate   = 0.08
dice_loss      = True
learning_rate  = 0.001
show_summary   = False

[train]
epochs        = 100
batch_size    = 4
patience      = 10
metrics       = ["dice_coef", "val_dice_coef"]
model_dir     = "./dice_loss_models"
eval_dir      = "./dice_loss_eval"

image_datapath = "../../../dataset/BrainTumor/train/image/"
mask_datapath  = "../../../dataset/BrainTumor/train/mask/"

[eval]
image_datapath = "../../../dataset/BrainTumor/test/image/"
mask_datapath  = "../../../dataset/BrainTumor/test/mask/"

[infer] 
images_dir    = "./mini_test" 
output_dir    = "./mini_test_output_dice_loss"
